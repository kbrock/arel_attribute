#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "arel_attribute"

# any helper that is not rspec specific
Dir['./spec/support/**/*.rb'].sort.select { |f| !File.read(f).include?("RSpec") }.each { |f| require f }

